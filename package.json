{
  "name": "twitcanva",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run worker\" \"vite\"",
    "dev:no-worker": "concurrently \"npm run server\" \"vite\"",
    "server": "node server/index.js",
    "worker": "node server/worker.js",
    "build": "vite build",
    "build:test": "vite build --mode test",
    "build:prod": "vite build --mode production",
    "start": "NODE_ENV=production concurrently \"node server/index.js\" \"node server/worker.js\"",
    "start:test": "NODE_ENV=production concurrently \"node server/index.js\" \"node server/worker.js\"",
    "start:prod": "NODE_ENV=production concurrently \"node server/index.js\" \"node server/worker.js\"",
    "start:worker": "NODE_ENV=production node server/worker.js",
    "preview": "vite preview",
    "electron:dev": "cross-env ELECTRON=1 vite build && tsc -p electron/tsconfig.json && electron .",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:build": "cross-env ELECTRON=1 vite build && npm run electron:compile && electron-builder",
    "electron:build:win": "cross-env ELECTRON=1 vite build && npm run electron:compile && electron-builder --win",
    "electron:build:mac": "cross-env ELECTRON=1 vite build && npm run electron:compile && electron-builder --mac",
    "setup:local-models": "node -e \"require('child_process').execSync(process.platform === 'win32' ? 'setup-local-models.bat' : 'bash setup-local-models.sh', {stdio: 'inherit'})\"",
    "setup:vsr": "node -e \"require('child_process').execSync(process.platform === 'win32' ? 'setup-vsr.bat' : 'bash setup-vsr.sh', {stdio: 'inherit'})\""
  },
  "dependencies": {
    "@fal-ai/client": "^1.9.5",
    "@google/genai": "^1.32.0",
    "@langchain/core": "^1.1.40",
    "@langchain/google-genai": "^2.0.4",
    "@langchain/langgraph": "^1.2.8",
    "amqplib": "^1.0.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "face-api.js": "^0.22.2",
    "form-data": "^4.0.5",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lodash-es": "^4.18.1",
    "lucide-react": "^0.556.0",
    "multer": "^2.1.1",
    "mysql2": "^3.22.0",
    "opencc-js": "^1.0.5",
    "puppeteer-core": "^24.42.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
