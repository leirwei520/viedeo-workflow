# ============================================================================
# Environment configuration template
# 环境变量配置模板
#
# Copy this file to `.env` (or `.env.production` / `.env.test`) and fill in
# your own values. NEVER commit real credentials to version control.
# 复制本文件为 .env 并填入你自己的配置，切勿将真实密钥提交到仓库。
# ============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=development
VITE_APP_ENV=development
# Frontend -> backend base URL. Leave empty to auto-detect / use same origin.
VITE_API_BASE_URL=http://localhost:3001
# Backend listen port (server default is 3001)
PORT=3001

# ---- Object Storage (Aliyun OSS or S3-compatible) ---------------------------
OSS_ENDPOINT=oss-cn-region.aliyuncs.com
OSS_INTERNAL_ENDPOINT=
OSS_BUCKET=your-bucket
OSS_ACCESS_KEY=your-oss-access-key
OSS_ACCESS_SECRET=your-oss-access-secret
# Optional custom CDN/CNAME domain bound to the bucket (no protocol).
OSS_DOMAIN=
# Frontend counterpart of OSS_DOMAIN, used to recognize OSS asset URLs.
VITE_OSS_CUSTOM_DOMAIN=

# ---- MySQL ------------------------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=your_database
MYSQL_CHARSET=utf8mb4
MYSQL_POOL_SIZE=30

# ---- Redis ------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=your-redis-password

# ---- RabbitMQ (async task queue) --------------------------------------------
RABBITMQ_URL=amqp://localhost
RABBITMQ_IMAGE_CONCURRENCY=10
RABBITMQ_VIDEO_CONCURRENCY=5
RABBITMQ_USER_MAX_CONCURRENT=20

# ---- Auth -------------------------------------------------------------------
# REQUIRED in production. Use a long random string (e.g. `openssl rand -hex 32`).
JWT_SECRET=change-me-to-a-strong-random-secret

# ---- Chat / LLM -------------------------------------------------------------
CHAT_API_KEY=your-llm-api-key
CHAT_BASE_URL=https://your-llm-endpoint.example.com/compatible-mode/v1
CHAT_MODEL=your-chat-model
CHAT_FALLBACK_MODEL=your-fallback-model
CHAT_FAST_MODEL=your-fast-model
AGENT_MODEL=your-agent-model
AGENT_FALLBACK_MODEL=your-agent-fallback-model
AGENT_MAX_ITERATIONS=10
STORYBOARD_MODEL=your-storyboard-model
STORYBOARD_IMAGE_MODEL=

# ---- Gemini -----------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_BASE_URL=https://your-gemini-endpoint.example.com/v1beta/models

# ---- OpenAI (optional) ------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key

# ---- Kling (video) ----------------------------------------------------------
KLING_ACCESS_KEY=your-kling-access-key
KLING_SECRET_KEY=your-kling-secret-key

# ---- Hailuo (video) ---------------------------------------------------------
HAILUO_API_KEY=your-hailuo-api-key

# ---- fal.ai -----------------------------------------------------------------
FAL_API_KEY=your-fal-api-key

# ---- Volcengine Ark (Seedance video) ----------------------------------------
ARK_API_KEY=your-ark-api-key
ARK_MODEL_ID=your-ark-model-id

# ---- Volcengine TTS ---------------------------------------------------------
VOLC_ACCESS_KEY=your-volc-access-key
VOLC_SECRET_KEY=your-volc-secret-key
VOLC_TTS_API_KEY=your-volc-tts-api-key
VOLC_TTS_MODEL_ID=volc-tts
VOLC_TTS_CLONE_MODEL_ID=volc-tts-clone

# ---- ChuHaiBang image API ---------------------------------------------------
CHB_API_KEY=your-chb-api-key
CHB_BASE_URL=https://your-chb-endpoint.example.com/api

# ---- Tencent VOD (video hosting) --------------------------------------------
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key
TENCENT_SUB_APP_ID=your-tencent-sub-app-id
TENCENT_REGION=ap-guangzhou

# ---- Self-hosted AI microservices -------------------------------------------
INDEX_TTS_BASE=https://your-ai-service.example.com/index-tts
INDEX_TTS_API_KEY=your-index-tts-api-key
FASTER_WHISPER_BASE=https://your-ai-service.example.com/faster-whisper
FASTER_WHISPER_API_KEY=your-faster-whisper-api-key
# Video subtitle remover service
VSR_ENDPOINT=http://localhost:8101
# Camera-angle generation service
VITE_MODAL_CAMERA_ENDPOINT=http://localhost:8100/generate
# Cobalt media downloader (optional)
COBALT_API_URL=

# ---- Local paths (optional) -------------------------------------------------
LIBRARY_DIR=
LOCAL_MODELS_DIR=
